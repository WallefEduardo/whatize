# NODE_ENV definido abaixo na seção de logs
BACKEND_URL=https://apizap.zmaxsys.com.br
FRONTEND_URL=https://zap.zmaxsys.com.br
PROXY_PORT=443
PORT=4035

# PostgreSQL
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=35439
DB_USER=workzap
DB_PASS=sua_senha_do_banco_aqui
DB_NAME=workzap

# JWT Configuração
JWT_SECRET=sua_chave_jwt_secreta_aqui
JWT_REFRESH_SECRET=sua_chave_jwt_refresh_secreta_aqui

# Redis
REDIS_URI=redis://:sua_senha_redis@127.0.0.1:26739
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

# Configuração da API da OpenAI
OPENAI_API_KEY=your_openai_api_key

# Limites do Sistema
USER_LIMIT=999
CONNECTIONS_LIMIT=999
CLOSED_SEND_BY_ME=true

# Configuração do Gerencianet
GERENCIANET_SANDBOX=false
GERENCIANET_CLIENT_ID=sua-id
GERENCIANET_CLIENT_SECRET=sua_chave_secreta
GERENCIANET_PIX_CERT=nome_do_certificado
GERENCIANET_PIX_KEY=chave_pix_gerencianet

# ============================================
# 📱 FACEBOOK/INSTAGRAM API CONFIGURATION
# ============================================
# Configurações obrigatórias para integração Facebook/Instagram

# Credenciais do App Facebook (configurado para desenvolvimento)
FACEBOOK_APP_ID=1443021550275833
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_ACCESS_TOKEN=c1ef9d5fae9c5f8eb517a5c527acff0a

# Token de verificação do webhook (deve ser igual ao configurado no Facebook)
VERIFY_TOKEN=whatize_webhook_verify_token_2024

# Configurações da Meta API
META_API_VERSION=v22.0
META_API_BASE_URL=https://graph.facebook.com

# ============================================
# 📸 INSTAGRAM API CONFIGURATION (NOVA - FASE 3)
# ============================================

# Habilitar nova API do Instagram Business
INSTAGRAM_API_ENABLED=true

# Configurações específicas do Instagram
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# Rate limiting específico para Instagram
INSTAGRAM_RATE_LIMIT_PER_HOUR=200
INSTAGRAM_RATE_LIMIT_PER_DAY=4800

# ============================================
# 🔒 CONFIGURAÇÕES DE SEGURANÇA WEBHOOK
# ============================================

# Controle de verificação de assinatura (recomendado: sempre true em produção)
# Em desenvolvimento, pode ser definido como 'true' para pular verificação
SKIP_WEBHOOK_SIGNATURE=false

# Rate limiting para webhooks (requests por minuto)
FACEBOOK_RATE_LIMIT_PER_MINUTE=100
FACEBOOK_STRICT_RATE_LIMIT_PER_MINUTE=20

# ============================================
# 📊 CONFIGURAÇÕES AVANÇADAS DA API (FASE 2)
# ============================================

# Habilitar logs detalhados de webhook (true/false)
FACEBOOK_WEBHOOK_DETAILED_LOGS=false

# Timeout para requisições da Meta API (em millisegundos)
FACEBOOK_API_TIMEOUT=30000

# Sistema de Retry Automático (Fase 2 - Novo!)
FACEBOOK_API_AUTO_RETRY=true
FACEBOOK_API_MAX_RETRIES=3

# Delay base para retry com exponential backoff (em millisegundos)
# O delay real será: baseDelay * 2^tentativa (com jitter)
FACEBOOK_API_RETRY_BASE_DELAY=1000

# Cache de clientes API (otimização de performance)
FACEBOOK_CLIENT_CACHE_ENABLED=true
FACEBOOK_CLIENT_CACHE_TTL=1800  # 30 minutos em segundos

# Logs de estatísticas da API (útil para monitoramento)
FACEBOOK_API_STATS_LOGS=true
FACEBOOK_API_STATS_INTERVAL=300000  # Log stats a cada 5 minutos (em ms)

# ============================================
# 📊 CONFIGURAÇÕES DE MONITORAMENTO (FASE 4)
# ============================================

# Sistema de Logs Específico
FACEBOOK_LOG_LEVEL=info
FACEBOOK_TELEMETRY_ENABLED=true
FACEBOOK_TELEMETRY_SAMPLING_RATE=1.0
FACEBOOK_TELEMETRY_RETENTION_DAYS=30
FACEBOOK_TELEMETRY_EXPORT_ENABLED=false
FACEBOOK_TELEMETRY_EXPORT_INTERVAL=3600000
FACEBOOK_TELEMETRY_ANONYMIZE=false

# Health Checks
FACEBOOK_HEALTH_CHECK_ENABLED=true
FACEBOOK_HEALTH_CHECK_INTERVAL=60000
FACEBOOK_HEALTH_CHECK_TIMEOUT=10000
FACEBOOK_HEALTH_CHECK_RETRIES=3
FACEBOOK_HEALTH_CHECK_ALERTS=true

# Sistema de Alertas
FACEBOOK_ALERTS_ENABLED=true
FACEBOOK_ALERT_COOLDOWN=300000
FACEBOOK_ALERT_ERROR_RATE=5
FACEBOOK_ALERT_RESPONSE_TIME=5000
FACEBOOK_ALERT_FAILED_REQUESTS=10
FACEBOOK_ALERT_CACHE_HIT_RATE=70
FACEBOOK_ALERT_HEALTH_FAILURES=3
FACEBOOK_ALERT_QUOTA_USAGE=90

# Canais de Alerta - Email
FACEBOOK_ALERT_EMAIL_ENABLED=false
FACEBOOK_ALERT_EMAIL_FROM=noreply@yourcompany.com
FACEBOOK_ALERT_EMAIL_TO=admin@yourcompany.com,support@yourcompany.com
FACEBOOK_ALERT_SMTP_HOST=smtp.gmail.com
FACEBOOK_ALERT_SMTP_PORT=587
FACEBOOK_ALERT_SMTP_SECURE=true
FACEBOOK_ALERT_SMTP_USER=your_email@gmail.com
FACEBOOK_ALERT_SMTP_PASS=your_app_password

# Canais de Alerta - Webhook
FACEBOOK_ALERT_WEBHOOK_URL=https://your-webhook.com/facebook-alerts
FACEBOOK_ALERT_WEBHOOK_TOKEN=your_webhook_auth_token

# Canais de Alerta - Slack
FACEBOOK_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Métricas e Performance
FACEBOOK_METRICS_AGGREGATION_INTERVAL=300000
FACEBOOK_METRICS_SNAPSHOTS_RETENTION=288
FACEBOOK_METRICS_EXPORT_FORMAT=json

# ============================================
# 🧪 CONFIGURAÇÕES DE DESENVOLVIMENTO
# ============================================
# Para usar com ngrok ou ambiente local

# URL do webhook para desenvolvimento (gerada pelo ngrok)
# WEBHOOK_DEV_URL=https://abc123.ngrok.io

# Habilitar modo debug avançado (logs extras)
# FACEBOOK_DEBUG_MODE=true

# IPs permitidos para bypass de rate limiting (separados por vírgula)
# FACEBOOK_ALLOWED_IPS=127.0.0.1,::1,localhost

# ============================================
# 📧 CONFIGURAÇÃO DE EMAILS (OPCIONAL)
# ============================================
# Descomente e configure para ativar emails

# Gmail (Recomendado)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=seu-email@gmail.com
# MAIL_PASS=sua-senha-de-app-do-gmail
# MAIL_FROM=seu-email@gmail.com

# Outlook
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USER=seu-email@outlook.com
# MAIL_PASS=sua-senha-outlook
# MAIL_FROM=seu-email@outlook.com

# Servidor SMTP Personalizado
# MAIL_HOST=smtp.seuservidor.com
# MAIL_PORT=587
# MAIL_USER=seu-usuario
# MAIL_PASS=sua-senha
# MAIL_FROM=noreply@seudominio.com

# ============================================
# 🚨 SISTEMA DE MONITORAMENTO E ALERTAS
# ============================================
# Email para receber alertas de problemas críticos
# SUPORTE A MÚLTIPLOS EMAILS - Separe por vírgula, ponto-e-vírgula ou espaço
ALERT_EMAIL=seu-email@gmail.com,admin@empresa.com

# ============================================
# LOGS DE DEBUG (DESENVOLVIMENTO)
# ============================================
NODE_ENV=production      # Em produção: SEM logs de debug
# NODE_ENV=development   # Em desenvolvimento: COM logs de debug  
DEBUG_LOGS=false         # Força desativar logs (ATIVO)

# Webhook para Slack/Discord (opcional)
# ALERT_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Nome do servidor (para identificar nos alertas)
# SERVER_NAME=servidor-producao

# ============================================
# 🔧 CONFIGURAÇÃO GIT (ADICIONADO AUTOMATICAMENTE)
# ============================================
# Estas variáveis são adicionadas automaticamente pelo painel de monitoramento
# Não edite manualmente - use a Opção 14 do painel

# GitHub/GitLab Username
# GIT_USERNAME=seu-usuario-github

# Personal Access Token (GitHub) ou Access Token (GitLab)
# GIT_TOKEN=ghp_seu_personal_access_token_aqui

# Configuração SMTP (Configurado automaticamente)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=seu-email@gmail.com
# MAIL_PASS=sua-senha-de-app
# MAIL_FROM=seu-email@gmail.com

# Configurações Git (Configuradas automaticamente)
# GIT_REPOSITORY_URL=https://github.com/usuario/repositorio.git
# GIT_USER_NAME=Seu Nome
# GIT_USER_EMAIL=seu-email@gmail.com
# GIT_USERNAME=seu-usuario-github
# GIT_TOKEN=ghp_seu_token_aqui 