NODE_ENV=development
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
PROXY_PORT=
PORT=4000

# PostgreSQL
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=55433
DB_USER=whatize
DB_PASS=sua_senha_do_banco
DB_NAME=whatize

# JWT Configuração
JWT_SECRET=sua_chave_jwt_secreta_aqui
JWT_REFRESH_SECRET=sua_chave_jwt_refresh_secreta_aqui

# Redis
REDIS_URI=redis://:sua_senha_redis@localhost:56380
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

# Configuração da API da OpenAI
OPENAI_API_KEY=your_openai_api_key

# Limites do Sistema
USER_LIMIT=999
CONNECTIONS_LIMIT=999
CLOSED_SEND_BY_ME=true

# Configuração do Gerencianet
GERENCIANET_SANDBOX=false
GERENCIANET_CLIENT_ID=sua-id
GERENCIANET_CLIENT_SECRET=sua_chave_secreta
GERENCIANET_PIX_CERT=nome_do_certificado
GERENCIANET_PIX_KEY=chave_pix_gerencianet

# ============================================
# 📧 CONFIGURAÇÃO DE EMAILS (OPCIONAL)
# ============================================
# Descomente e configure para ativar emails

# Gmail (Recomendado)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=seu-email@gmail.com
# MAIL_PASS=sua-senha-de-app-do-gmail
# MAIL_FROM=seu-email@gmail.com

# Outlook
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USER=seu-email@outlook.com
# MAIL_PASS=sua-senha-outlook
# MAIL_FROM=seu-email@outlook.com

# Servidor SMTP Personalizado
# MAIL_HOST=smtp.seuservidor.com
# MAIL_PORT=587
# MAIL_USER=seu-usuario
# MAIL_PASS=sua-senha
# MAIL_FROM=noreply@seudominio.com

# ============================================
# 🚨 SISTEMA DE MONITORAMENTO E ALERTAS
# ============================================
# Email para receber alertas de problemas críticos
# ALERT_EMAIL=admin@empresa.com

# Webhook para Slack/Discord (opcional)
# ALERT_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Nome do servidor (para identificar nos alertas)
# SERVER_NAME=servidor-producao

# ============================================
# 🔧 CONFIGURAÇÃO GIT (ADICIONADO AUTOMATICAMENTE)
# ============================================
# Estas variáveis são adicionadas automaticamente pelo painel de monitoramento
# Não edite manualmente - use a Opção 14 do painel

# GitHub/GitLab Username
# GIT_USERNAME=seu-usuario-github

# Personal Access Token (GitHub) ou Access Token (GitLab)
# GIT_TOKEN=ghp_seu_personal_access_token_aqui 