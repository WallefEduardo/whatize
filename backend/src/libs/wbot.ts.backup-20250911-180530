        // 🚦 RATE LIMITING: Sistema inteligente de controle de mensagens
        let lastMessageTime = 0;
        const MIN_MESSAGE_INTERVAL = 1500; // Mínimo 1.5s entre mensagens
        
        // Interceptar sendMessage para adicionar rate limiting
        const originalSendMessage = wsocket.sendMessage;
        wsocket.sendMessage = async function(jid: string, message: any, options?: any) {
          const now = Date.now();
          const timeSinceLastMessage = now - lastMessageTime;
          
          // Aplicar delay se necessário
          if (timeSinceLastMessage < MIN_MESSAGE_INTERVAL) {
            const delayNeeded = MIN_MESSAGE_INTERVAL - timeSinceLastMessage;
            logger.debug(`🚦 [RATE-LIMIT] ${name} - Aguardando ${delayNeeded}ms antes de enviar mensagem`);
            await new Promise(resolve => setTimeout(resolve, delayNeeded));
          }
          
          try {
            const result = await originalSendMessage.call(this, jid, message, options);
            lastMessageTime = Date.now();
            return result;
          } catch (err) {
            logger.error(`🚦 [RATE-LIMIT-ERROR] ${name}: ${err.message}`);
            throw err;
          }
        };

        wsocket.ev.on("creds.update", async (creds) => {
          logger.info(`🔑 [CREDS-UPDATE] INICIO: { name: '${name}', hasUpdate: ${!!creds} }`);
          try {
            // ✅ VALIDAÇÃO: Verificar se credenciais são válidas antes de salvar
            if (!creds || typeof creds !== 'object') {
              logger.warn(`⚠️ [CREDS-UPDATE] ${name} - Credenciais inválidas recebidas`);
              return;
            }
            
            await saveCreds();
            
            // ✅ VALIDAÇÃO: Verificar se credenciais foram salvas corretamente
            const { state: verifyState } = await useMultiFileAuthState(whatsapp);
            if (!verifyState?.creds?.noiseKey) {
              logger.error(`❌ [CREDS-UPDATE] ${name} - Falha na verificação das credenciais salvas`);
              throw new Error('Credenciais não foram salvas corretamente');
            }
            
            logger.info(`🔑 [CREDS-UPDATE] CONCLUIDO: { name: '${name}' }`);
          } catch (error) {
            logger.error(`❌ [CREDS-UPDATE] ERRO CRITICO: { name: '${name}', error: ${error.message}, stack: ${error.stack} }`);
            
            // ✅ FALLBACK: Se falhar ao salvar credenciais, desconectar para evitar estado inconsistente
            logger.error(`🔑 [CREDS-FALLBACK] ${name} - Desconectando devido a falha nas credenciais`);
            wsocket.logout();
            throw error;
          }
        });
        // wsocket.store = store;
        // store.bind(wsocket.ev);
      })();
    } catch (error) {
      Sentry.captureException(error);
      console.log(error);
      reject(error);
