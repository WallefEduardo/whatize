              // ✅ MONITORAMENTO: Iniciar heartbeat, monitoramento de recursos e health check quando conectado
              logger.info(`❤️ [MONITORING-START] Iniciando monitoramento completo para ${name}`);
              startHeartbeat();
              startResourceMonitor();
              startConnectionHealthCheck();
              
              // ✅ RESET: Limpar contador de tentativas após conexão bem-sucedida
              retriesQrCodeMap.delete(id);
              logger.info(`🔄 [RETRY-RESET] Contador de reconexão resetado para ${name}`);

              // 🎯 CORREÇÃO: Recarregar objeto para ter status atualizado
              await whatsapp.reload();
              
              console.log(`🔥 [CONNECTED] Emitindo socket para frontend - Status: ${whatsapp.status}, ID: ${whatsapp.id}`);
              
              console.log(`🔍 [CONNECTED-DEBUG] Tentando criar socketData...`);
              
              try {
