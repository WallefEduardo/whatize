                  .emit(`company-${companyId}-whatsappSession`, {
                    action: "update",
                    session: wpp
                  });
              }, 1000 * 45);

            });
          }

        }, 2500);



      
        // ✅ MONITORAMENTO: Heartbeat e recursos do sistema
        let heartbeatInterval;
        let resourceMonitorInterval;
        let connectionHealthCheck;
        
        const startHeartbeat = () => {
          heartbeatInterval = setInterval(() => {
            try {
              logger.debug(`❤️ [HEARTBEAT] ${name} - Conexão ativa`);
            } catch (err) {
              logger.error(`💔 [HEARTBEAT-ERROR] ${name}: ${err.message}`);
              clearInterval(heartbeatInterval);
            }
          }, 60000); // Check a cada 1 minuto
        };
        
        // ✅ NOVO: Health check para detectar desconexões silenciosas
        const startConnectionHealthCheck = () => {
          connectionHealthCheck = setInterval(async () => {
            try {
              const ws = (wsocket as any).ws;
              const socket = (wsocket as any).socket;
              const readyState = ws?.readyState || socket?.readyState || (wsocket as any).readyState;
              const hasUser = !!(wsocket as any).user;
              
              if (wsocket && readyState === 1 && hasUser) {
                // Tentar ping para verificar se conexão está realmente ativa
                const startTime = Date.now();
                await wsocket.query({ tag: 'iq', attrs: { type: 'get', xmlns: 'jabber:iq:ping' } })
                  .catch(() => null); // Ignorar erros do ping
                const pingTime = Date.now() - startTime;
                
                if (pingTime > 10000) { // Ping > 10s indica problema
                  logger.warn(`🐌 [HEALTH-CHECK] ${name} - Ping lento: ${pingTime}ms`);
                } else {
                  logger.debug(`✅ [HEALTH-CHECK] ${name} - Conexão saudável (ping: ${pingTime}ms)`);
                }
              } else {
                logger.warn(`🔌 [HEALTH-CHECK] ${name} - Conexão não ativa: readyState=${readyState}, hasUser=${hasUser}`);
              }
            } catch (err) {
              logger.error(`❌ [HEALTH-CHECK-ERROR] ${name}: ${err.message}`);
            }
          }, 180000); // Check a cada 3 minutos
        };

        // 🔍 MONITORAMENTO DE RECURSOS: Detectar problemas de memória/CPU
        const startResourceMonitor = () => {
          resourceMonitorInterval = setInterval(() => {
            try {
              const memUsage = process.memoryUsage();
              const memUsedMB = Math.round(memUsage.heapUsed / 1024 / 1024);
              const memTotalMB = Math.round(memUsage.heapTotal / 1024 / 1024);
              
              // Logs apenas quando memória excede 100MB ou há problemas
              if (memUsedMB > 100) {
                logger.warn(`📊 [RESOURCE-MONITOR] ${name} - Memória elevada: ${memUsedMB}MB/${memTotalMB}MB`);
              }
              
              // Log de status da conexão (sem verificação de propriedades específicas do ws)
              if (wsocket) {
                logger.debug(`🔌 [RESOURCE-MONITOR] ${name} - Socket ativo e monitorado`);
              }
              
            } catch (err) {
              logger.error(`📊 [RESOURCE-MONITOR-ERROR] ${name}: ${err.message}`);
            }
          }, 120000); // Check a cada 2 minutos
        };

        wsocket.ev.on(
          "connection.update",
          async ({ connection, lastDisconnect, qr }) => {
            const timestamp = new Date().toISOString();
            logger.info(`🔌 [CONNECTION-UPDATE] ${timestamp} - ${name}: { connection: '${connection}', hasError: ${!!lastDisconnect}, hasQr: ${!!qr} }`);
            
            try {

            if (connection === "close") {
              // ✅ CLEANUP: Parar monitores quando desconectar
              if (heartbeatInterval) {
                clearInterval(heartbeatInterval);
                logger.info(`💔 [HEARTBEAT-STOPPED] Heartbeat parado para ${name}`);
              }
              if (resourceMonitorInterval) {
                clearInterval(resourceMonitorInterval);
                logger.info(`📊 [RESOURCE-MONITOR-STOPPED] Monitoramento de recursos parado para ${name}`);
              }
              if (connectionHealthCheck) {
                clearInterval(connectionHealthCheck);
                logger.info(`🔌 [HEALTH-CHECK-STOPPED] Health check parado para ${name}`);
              }
              
              const errorDetails = lastDisconnect?.error || {};
              const statusCode = (lastDisconnect?.error as Boom)?.output?.statusCode;
              const timestamp = new Date().toISOString();
              
              logger.error(`🔌 [DISCONNECT-DETECTED] WhatsApp ${name} (ID: ${id}) desconectado em ${timestamp}:`);
