              logger.error(`🔌 [DISCONNECT-ERROR] ${(errorDetails as any)?.message || 'No error message'}`);
              logger.error(`🔌 [DISCONNECT-FULL] ${JSON.stringify(lastDisconnect, null, 2)}`);
              
              console.log(`🚨 [${timestamp}] DESCONEXÃO DETECTADA - ${name}:`, JSON.stringify(lastDisconnect, null, 2));
              
              // ✅ CORREÇÃO: Detectar erros de sessão corrompida (Bad MAC, pre-keys, etc.)
              const errorMessage = (lastDisconnect?.error as any)?.message || '';
              const isSessionCorrupted = errorMessage.includes('Bad MAC') || 
                                       errorMessage.includes('pre-key') || 
                                       errorMessage.includes('session') ||
                                       errorMessage.includes('decrypt') ||
                                       statusCode === 428; // Session expired
              
              // ✅ NOVO: Detectar conflito de conexão (múltiplas sessões)
              const isConnectionConflict = statusCode === 440 || errorMessage.includes('conflict') || errorMessage.includes('replaced');
              
              if (isConnectionConflict) {
                logger.error(`🔥 [CONNECTION-CONFLICT] ${name} - Conflito de conexão detectado! Parando tentativas.`);
                await whatsapp.update({ status: "DISCONNECTED", session: "" });
                await DeleteBaileysService(whatsapp.id);
                await cacheLayer.delFromPattern(`sessions:${whatsapp.id}:*`);
                io.of(`/${companyId}`)
                  .emit(`company-${whatsapp.companyId}-whatsappSession`, {
                    action: "update",
                    session: whatsapp
                  });
                removeWbot(id, false);
                
                // NÃO tentar reconectar automaticamente em caso de conflito
                logger.warn(`⚠️ [CONNECTION-CONFLICT] ${name} - Conflito resolvido. Reconexão manual necessária.`);
                return;
              }
              
              if (isSessionCorrupted) {
                logger.error(`🔑 [SESSION-CORRUPTED] ${name} - Sessão corrompida detectada: ${errorMessage}`);
                await whatsapp.update({ status: "PENDING", session: "" });
                await DeleteBaileysService(whatsapp.id);
                await cacheLayer.delFromPattern(`sessions:${whatsapp.id}:*`);
                io.of(`/${companyId}`)
                  .emit(`company-${whatsapp.companyId}-whatsappSession`, {
                    action: "update",
                    session: whatsapp
                  });
                removeWbot(id, false);
                
                // Tentar reconectar após limpar sessão corrompida
                setTimeout(() => {
                  logger.info(`🔄 [RECONNECT-CORRUPTED] Tentando reconectar ${name} após sessão corrompida`);
                  StartWhatsAppSession(whatsapp, whatsapp.companyId);
                }, 5000);
                return;
              }
              
              if ((lastDisconnect?.error as Boom)?.output?.statusCode === 403) {
                await whatsapp.update({ status: "PENDING", session: "" });
                await DeleteBaileysService(whatsapp.id);
                await cacheLayer.delFromPattern(`sessions:${whatsapp.id}:*`);
                io.of(`/${companyId}`)
                  .emit(`company-${whatsapp.companyId}-whatsappSession`, {
                    action: "update",
                    session: whatsapp
                  });
                removeWbot(id, false);
              }
              if (
                (lastDisconnect?.error as Boom)?.output?.statusCode !==
                DisconnectReason.loggedOut
              ) {
                // ✅ BACKOFF: Implementar backoff exponencial para reconexões
                const retryAttempt = retriesQrCodeMap.get(id) || 0;
                const maxRetries = 10; // Máximo 10 tentativas
                
                if (retryAttempt >= maxRetries) {
                  logger.error(`❌ [MAX-RETRIES] ${name} atingiu limite máximo de ${maxRetries} tentativas de reconexão`);
                  await whatsapp.update({ status: "DISCONNECTED" });
                  retriesQrCodeMap.delete(id);
                  removeWbot(id, false);
                  return;
                }
                
                const backoffDelay = Math.min(2000 * Math.pow(2, retryAttempt), 30000); // Max 30s
                
                logger.info(`🔄 [RECONNECT-ATTEMPT] Tentativa ${retryAttempt + 1}/${maxRetries} para ${name} em ${backoffDelay/1000}s (não foi logout)`);
                retriesQrCodeMap.set(id, retryAttempt + 1);
                
                removeWbot(id, false);
                setTimeout(() => {
                  logger.info(`🔄 [RECONNECT-START] Iniciando reconexão ${retryAttempt + 1}/${maxRetries} para ${name}`);
                  StartWhatsAppSession(whatsapp, whatsapp.companyId);
                }, backoffDelay);
              } else {
                logger.warn(`🔓 [LOGOUT-DETECTED] ${name} foi deslogado - limpando sessão e tentando reconectar`);
                await whatsapp.update({ status: "PENDING", session: "" });
                await DeleteBaileysService(whatsapp.id);
                await cacheLayer.delFromPattern(`sessions:${whatsapp.id}:*`);
                io.of(`/${companyId}`)
                  .emit(`company-${whatsapp.companyId}-whatsappSession`, {
                    action: "update",
                    session: whatsapp
                  });
                removeWbot(id, false);
                setTimeout(() => {
                  logger.info(`🔄 [RECONNECT-LOGOUT] Tentando reconectar ${name} após logout`);
                  StartWhatsAppSession(whatsapp, whatsapp.companyId);
                }, 2000);
              }
            }

            if (connection === "open") {
              const phoneNumber = wsocket.type === "md"
                ? jidNormalizedUser((wsocket as WASocket).user.id).split("@")[0]
                : "-";

              // ✅ VALIDAÇÃO: Verificar se número já está em uso por outra empresa
              if (phoneNumber !== "-") {
                const { default: ValidateWhatsappConnectionService } = await import("../services/WhatsappService/ValidateWhatsappConnectionService");
                try {
                  await ValidateWhatsappConnectionService({
                    name: whatsapp.name,
                    number: phoneNumber,
                    companyId: whatsapp.companyId,
                    id: whatsapp.id
                  });
                } catch (validationError) {
                  // Se a validação falhar, desconecta e define status como erro
                  logger.error(`❌ Validação falhou para WhatsApp ${whatsapp.name}: ${validationError.message}`);
                  
                  await whatsapp.update({
                    status: "DISCONNECTED",
                    qrcode: "",
                    retries: 0,
                    number: ""
                  });

                  // Emitir erro para o frontend
                  io.of(`/${companyId}`)
                    .emit(`company-${whatsapp.companyId}-whatsappSession`, {
                      action: "validation_error",
                      session: whatsapp,
                      error: validationError.message
                    });

                  // Fechar conexão
                  wsocket.logout();
                  wsocket.ws.close();
                  removeWbot(id, false);
                  return;
                }
              }

              await whatsapp.update({
                status: "CONNECTED",
                qrcode: "",
                retries: 0,
                number: phoneNumber
